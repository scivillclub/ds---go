# dsgoaccount 서버의 로그인 페이지
NEXT_PUBLIC_DSGO_ACCOUNT_URL=http://localhost:3001

# 서버에서 SSO 토큰을 중앙 검증할 때 사용 (생략하면 위 공개 URL 사용)
DSGO_ACCOUNT_URL=http://localhost:3001

# 이 앱 자신의 배포 주소 (SSO 콜백 redirect_uri 생성에 사용)
NEXT_PUBLIC_SITE_URL=https://dsgo.vercel.app

# dsgo 자체 세션 서명용 (다른 앱과 공유할 필요 없음)
SESSION_SECRET=your_session_secret_here

# 각 서비스의 배포 주소 (생략하면 현재 Scivill 배포 주소를 사용합니다)
NEXT_PUBLIC_DEEPTHINK_URL=https://scivill-deepthink.vercel.app
NEXT_PUBLIC_ONSHEET_URL=https://scivill-sheet.vercel.app
NEXT_PUBLIC_ORYAFORM_URL=https://scivill-oryaform.vercel.app
NEXT_PUBLIC_QRLINK_URL=https://scivill-qrlink.vercel.app
